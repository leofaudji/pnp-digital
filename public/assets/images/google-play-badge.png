    <section id="better-together-fast-pair-desktop-us"
      class="android-hero-full-bleed android-spacer-margin-top--3 android-spacer-margin-bottom--3 android-spacer-padding-bottom--3 hidden--xs hidden--sm hidden--md hidden--lg nimble-priority-component android-hero-full-bleed--reversed android-hero-full-bleed--full-bleed android-hero-full-bleed--vertical-reversed android-hero-full-bleed--small-container android-hero-full-bleed--black android-hero-full-bleed--left"
